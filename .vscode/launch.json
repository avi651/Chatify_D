{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter Mock (Mock)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "program": "lib/main.dart",
            "args": [
                "--dart-define=ENV=mock",
                "--dart-define=API_KEY=",
                "--dart-define=feature_flags=mock,no_log_jornal,show_logs,no_proxy"
            ]
        },
        {
            "name": "Flutter Dev (ENV)",
